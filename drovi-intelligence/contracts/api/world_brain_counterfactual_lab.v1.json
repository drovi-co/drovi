{
  "version": "1.0",
  "domain": "world_brain",
  "contract": "counterfactual_lab",
  "description": "A/B counterfactual simulation comparison and intervention preview.",
  "endpoints": [
    {
      "path": "/api/v1/brain/counterfactual-lab/compare",
      "method": "POST",
      "request": {
        "organization_id": "string",
        "scenario_a": "BrainSimulationRequest",
        "scenario_b": "BrainSimulationRequest",
        "target_ref": "string",
        "generate_interventions": "boolean"
      },
      "response": {
        "success": "boolean",
        "comparison": "CounterfactualComparison"
      }
    }
  ],
  "types": {
    "CounterfactualComparison": {
      "preferred": "a|b|tie",
      "score_a": "number",
      "score_b": "number",
      "delta": "number",
      "scenario_a": "SimulationResponse",
      "scenario_b": "SimulationResponse",
      "intervention_previews": "object"
    }
  }
}
