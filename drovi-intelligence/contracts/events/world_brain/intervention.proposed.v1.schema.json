        "proposed_at": {
          "format": "date-time",
          "title": "Proposed At",
          "type": "string"
        },
        "rollback_plan": {
          "additionalProperties": true,
          "title": "Rollback Plan",
          "type": "object"
        },
        "status": {
          "title": "Status",
          "type": "string"
