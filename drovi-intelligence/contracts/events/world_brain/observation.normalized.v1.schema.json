{
  "$defs": {
    "ObservationNormalizedPayload": {
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "embedding_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Embedding Ref"
        },
        "entities": {
          "items": {
            "type": "string"
          },
          "title": "Entities",
          "type": "array"
        },
        "normalized_text": {
          "title": "Normalized Text",
          "type": "string"
        },
        "observation_id": {
          "title": "Observation Id",
          "type": "string"
        },
        "valid_from": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid From"
        },
        "valid_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid To"
        }
      },
      "required": [
        "observation_id",
        "normalized_text",
        "confidence"
      ],
      "title": "ObservationNormalizedPayload",
      "type": "object"
    }
  },
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "const": "observation.normalized.v1",
      "default": "observation.normalized.v1",
      "title": "Event Type",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "organization_id": {
      "title": "Organization Id",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/ObservationNormalizedPayload"
    },
    "producer": {
      "default": "drovi-intelligence",
      "title": "Producer",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "organization_id",
    "event_id",
    "occurred_at",
    "payload"
  ],
  "title": "ObservationNormalizedEvent",
  "type": "object"
}
