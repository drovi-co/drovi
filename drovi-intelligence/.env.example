# Drovi Intelligence Backend Environment Variables

# Database (shared with TypeScript backend)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/memorystack

# FalkorDB (Graph Database - Redis-compatible)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=drovi

# Redis (for events/caching)
REDIS_URL=redis://localhost:6379/0

# LLM Providers - Open Source (Preferred)
TOGETHER_API_KEY=tgp_...
FIREWORKS_API_KEY=...
HUGGINGFACE_API_KEY=...

# LLM Providers - Proprietary (Fallback)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...

# LLM Settings - Open Source Defaults
DEFAULT_MODEL_FAST=moonshotai/Kimi-K2.5
DEFAULT_MODEL_BALANCED=moonshotai/Kimi-K2.5
DEFAULT_MODEL_POWERFUL=moonshotai/Kimi-K2.5
EMBEDDING_MODEL=text-embedding-3-small

# LLM Settings - Legacy
DEFAULT_LLM_MODEL=gpt-4o
FALLBACK_LLM_MODEL=claude-3-5-sonnet-20241022

# TypeScript Backend Integration
TS_BACKEND_URL=http://localhost:3000
TS_INTERNAL_SECRET=your-internal-secret

# API Settings
API_KEY_SALT=your-api-key-salt
WORLD_NEWS_API_KEY=
CONNECTOR_TOKEN_ENCRYPTION_KEY=replace-with-managed-secret
# Optional comma-separated previous keys kept temporarily during rotation.
# New writes use CONNECTOR_TOKEN_ENCRYPTION_KEY; previous keys are decrypt-only.
CONNECTOR_TOKEN_ENCRYPTION_PREVIOUS_KEYS=
COGNITIVE_PAYLOAD_ENCRYPTION_KEY=replace-with-managed-secret
# Optional comma-separated previous keys kept temporarily during rotation.
# New writes use COGNITIVE_PAYLOAD_ENCRYPTION_KEY; previous keys are decrypt-only.
COGNITIVE_PAYLOAD_ENCRYPTION_PREVIOUS_KEYS=
# CORS_ORIGINS must be JSON array format for Pydantic
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance
MAX_CONCURRENT_ANALYSES=10
LLM_RATE_LIMIT_PER_MINUTE=60
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=30

# Scheduler
SCHEDULER_RUN_IN_API=true
SCHEDULER_ADVISORY_LOCK_ID=4242001
WORLD_INGEST_KILL_SWITCH_ENABLED=false
WORLD_INGEST_NONCRITICAL_PRIORITY_THRESHOLD=3
WORLD_INGEST_GLOBAL_THROTTLE_MULTIPLIER=1.0
# JSON map example:
# WORLD_INGEST_SOURCE_THROTTLE_MAP={"worldnewsapi":1.6,"rss_osint":1.3}
WORLD_INGEST_SOURCE_THROTTLE_MAP={}
WORLD_TWIN_HOT_CACHE_ENABLED=true
WORLD_TWIN_HOT_CACHE_TTL_SECONDS=120
# JSON list examples:
# WORLD_TWIN_PREMATERIALIZE_ROLES=["exec","legal","finance","product"]
# WORLD_TWIN_PREMATERIALIZE_LOOKBACKS=[24,168]
WORLD_TWIN_PREMATERIALIZE_ROLES=["exec","legal","finance","product"]
WORLD_TWIN_PREMATERIALIZE_LOOKBACKS=[24,168]
WORLD_CAPACITY_EVENT_RATE_BUDGET_EPS=10000
WORLD_CAPACITY_STORAGE_BUDGET_BYTES=5000000000000
WORLD_CAPACITY_GRAPH_NODE_BUDGET=5000000000
WORLD_AUTOSCALER_ENABLED=true
WORLD_AUTOSCALER_NAMESPACE=drovi
WORLD_AUTOSCALER_COOLDOWN_SECONDS=300
WORLD_AUTOSCALER_MAX_STEP=2
WORLD_AUTOSCALER_FRESHNESS_LOOKBACK_HOURS=6
WORLD_AUTOSCALER_SCALE_DOWN_QUEUE_THRESHOLD=5
WORLD_AUTOSCALER_SCALE_DOWN_FRESHNESS_THRESHOLD_MINUTES=20
WORLD_AUTOSCALER_FAIL_ON_ERRORS=true
# JSON map example:
# WORLD_AUTOSCALER_POOL_HPA_MAP={"normalize":"drovi-world-normalize-worker","graph":"drovi-world-graph-worker","ml":"drovi-world-ml-worker","simulation":"drovi-world-simulation-worker","critical":"drovi-world-critical-worker"}
# Durable jobs worker knobs
JOB_WORKER_POLL_INTERVAL_SECONDS=1
JOB_WORKER_LEASE_SECONDS=600
JOB_WORKER_REAPER_INTERVAL_SECONDS=60
JOB_WORKER_REAPER_LIMIT=500
# JSON list of allowed job types for dedicated worker pools; empty means claim all.
JOB_WORKER_ALLOWED_JOB_TYPES=[]
CRAWL_FRONTIER_ENABLED=true
CRAWL_FRONTIER_TICK_SECONDS=30
CRAWL_FRONTIER_DISPATCH_LIMIT=50
CRAWL_DOMAIN_CONCURRENCY_LIMIT=2
CRAWL_IDEMPOTENCY_BUCKET_SECONDS=120
CRAWL_FETCH_TIMEOUT_SECONDS=20
CRAWL_FETCH_MAX_ATTEMPTS=3
CRAWL_PROXY_URL=
CRAWL_USER_AGENT=DroviWorldCrawler/1.0 (+https://drovi.co/compliance)
CRAWL_RENDER_TIMEOUT_MS=30000
CRAWL_ROBOTS_ENFORCED=true
CRAWL_ROBOTS_TIMEOUT_SECONDS=5
# JSON list examples:
# CRAWL_DOMAIN_ALLOWLIST=["sec.gov","federalregister.gov"]
# CRAWL_DOMAIN_DENYLIST=["example.org"]
CRAWL_DOMAIN_ALLOWLIST=[]
CRAWL_DOMAIN_DENYLIST=[]
CRAWL_SIGNIFICANCE_THRESHOLD=0.22
WEEKLY_REPORTS_ENABLED=true
WEEKLY_REPORTS_CRON=0 9 * * MON
WEEKLY_REPORTS_PILOT_ONLY=true
WEEKLY_BRIEF_DAYS=7
WEEKLY_BLINDSPOT_DAYS=30
DAILY_REPORTS_ENABLED=true
DAILY_REPORTS_CRON=0 9 * * *
DAILY_REPORTS_PILOT_ONLY=true
DAILY_BRIEF_DAYS=1
REPORTS_EMAIL_ENABLED=false
REPORTS_EMAIL_FALLBACK_TO_MEMBERS=true
REPORTS_EMAIL_SUBJECT_PREFIX=
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
RESEND_API_URL=https://api.resend.com
RESEND_TIMEOUT_SECONDS=10

# Candidate processing
CANDIDATE_PROCESSING_ENABLED=true
CANDIDATE_PROCESSING_INTERVAL_SECONDS=60

# Evidence Storage (S3/MinIO)
EVIDENCE_STORAGE_BACKEND=s3
EVIDENCE_S3_BUCKET=drovi-evidence
EVIDENCE_S3_ENDPOINT_URL=http://localhost:9000
# Optional: endpoint to embed in presigned URLs returned to browsers.
# Useful when API runs in Docker and S3/MinIO is exposed on the host.
EVIDENCE_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
EVIDENCE_S3_ACCESS_KEY_ID=minioadmin
EVIDENCE_S3_SECRET_ACCESS_KEY=minioadmin
EVIDENCE_S3_PREFIX=drovi-evidence
EVIDENCE_S3_PRESIGN_EXPIRY_SECONDS=3600

# Lakehouse storage + quality gates
LAKEHOUSE_STORAGE_PATH=/tmp/drovi-lakehouse
LAKEHOUSE_TABLE_FORMAT=iceberg
LAKEHOUSE_RETENTION_DAYS_DEFAULT=365
LAKEHOUSE_LATE_ARRIVAL_GRACE_SECONDS=900
LAKEHOUSE_QUALITY_ENABLED=true
LAKEHOUSE_QUALITY_CRON=*/15 * * * *
LAKEHOUSE_RETENTION_ENABLED=true
LAKEHOUSE_RETENTION_CRON=45 4 * * *
LAKEHOUSE_QUALITY_MIN_COMPLETENESS=0.98
LAKEHOUSE_QUALITY_MIN_UNIQUENESS=0.995
LAKEHOUSE_QUALITY_MIN_FRESHNESS=0.9
LAKEHOUSE_QUALITY_MAX_STALENESS_SECONDS=604800
RETENTION_RAW_OBSERVATION_DAYS=3650
RETENTION_NORMALIZED_OBSERVATION_DAYS=1825
RETENTION_DERIVED_FEATURE_DAYS=1095
SOURCE_RELIABILITY_CALIBRATION_ENABLED=true
SOURCE_RELIABILITY_CALIBRATION_CRON=20 * * * *
SOURCE_RELIABILITY_LOOKBACK_DAYS=30
SOURCE_RELIABILITY_LIMIT_SOURCES=500

# Kafka Streaming
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_CONSUMER_GROUP_ID=drovi-intelligence
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_BATCH_SIZE=100
KAFKA_LINGER_MS=10
KAFKA_TOPIC_RAW_EVENTS=drovi-raw-events
KAFKA_TOPIC_INTELLIGENCE=drovi-intelligence
KAFKA_TOPIC_GRAPH_CHANGES=drovi-graph-changes
KAFKA_TOPIC_NORMALIZED_RECORDS=normalized.records
KAFKA_TOPIC_PIPELINE_INPUT=intelligence.pipeline.input
KAFKA_TOPIC_AGENT_INBOX_EVENTS=agent.inbox.events
KAFKA_TOPIC_CRAWL_FRONTIER=crawl.frontier.events
KAFKA_TOPIC_CRAWL_FETCH=crawl.fetch.events
KAFKA_TOPIC_CRAWL_PARSE=crawl.parse.events
KAFKA_TOPIC_CRAWL_DIFF=crawl.diff.events
KAFKA_WORKER_CONCURRENCY=4
KAFKA_QUEUE_MAXSIZE=1000
KAFKA_SCHEMA_REGISTRY_ENFORCED=true
# JSON map example with crawl topology:
# {"drovi-raw-events":0,"normalized.records":1,"intelligence.pipeline.input":2,"drovi-intelligence":3,"drovi-graph-changes":4,"agent.inbox.events":1,"crawl.frontier.events":0,"crawl.fetch.events":0,"crawl.parse.events":1,"crawl.diff.events":1}
KAFKA_TOPIC_PRIORITIES={"drovi-raw-events":0,"normalized.records":1,"intelligence.pipeline.input":2,"drovi-intelligence":3,"drovi-graph-changes":4,"agent.inbox.events":1,"crawl.frontier.events":0,"crawl.fetch.events":0,"crawl.parse.events":1,"crawl.diff.events":1}

# Live Streaming
STREAMING_QUEUE_SIZE=256
STREAMING_WORKER_CONCURRENCY=2
STREAMING_MAX_CHUNK_BYTES=5000000
STREAMING_MAX_LATENCY_MS=5000

# Webhook + Desktop Context
WEBHOOK_SHARED_SECRET=
DESKTOP_CONTEXT_ENABLED=true
DESKTOP_CONTEXT_MAX_BYTES=100000
DESKTOP_CONTEXT_TTL_SECONDS=300
