# =============================================================================
# LEADMINER - Docker Environment Configuration
# =============================================================================
# Copy this file to .env when deploying with Docker Compose
# All required variables must be set before running docker-compose up
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL in Docker)
# =============================================================================
POSTGRES_DB=memorystack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_PORT=5432

# Full connection string (used by the app, references Docker service name)
DATABASE_URL=postgresql://postgres:your-secure-postgres-password@postgres:5432/memorystack

# =============================================================================
# REDIS
# =============================================================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# =============================================================================
# NATS (Imperium)
# =============================================================================
NATS_URL=nats://nats:4222
IMPERIUM_HOST=0.0.0.0
IMPERIUM_PORT=8010
IMPERIUM_REDIS_NAMESPACE=imperium
IMPERIUM_SHUTDOWN_GRACE_SECONDS=20
IMPERIUM_DATA_MODE=synthetic
IMPERIUM_MARKETS_PROVIDER=polygon
IMPERIUM_MARKETS_FALLBACKS=finnhub,twelvedata
IMPERIUM_CRYPTO_PROVIDER=coinbase
IMPERIUM_CRYPTO_FALLBACKS=coingecko
IMPERIUM_NEWS_PROVIDER=benzinga
IMPERIUM_NEWS_FALLBACKS=newsapi,sec-rss
IMPERIUM_BANKING_PROVIDER=plaid
IMPERIUM_BANKING_FALLBACKS=truelayer
IMPERIUM_BROKERAGE_PROVIDER=snaptrade
IMPERIUM_BROKERAGE_FALLBACKS=alpaca
IMPERIUM_BUSINESS_PROVIDER=stripe
IMPERIUM_BUSINESS_FALLBACKS=quickbooks,polar
IMPERIUM_PROVIDER_MAX_RETRIES=2
IMPERIUM_PROVIDER_BACKOFF_MS=300
IMPERIUM_SEC_USER_AGENT=imperium-connectors/0.1 (ops@imperium.local)

# Imperium provider credentials
POLYGON_API_KEY=
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINGECKO_API_KEY=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
BENZINGA_API_KEY=
NEWSAPI_API_KEY=
FMP_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_ENV=sandbox
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# =============================================================================
# AUTHENTICATION (Better Auth)
# =============================================================================
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-char-secret-key-here-minimum
BETTER_AUTH_URL=https://api.yourdomain.com

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# PAYMENTS (Polar.sh)
# =============================================================================
POLAR_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
POLAR_SUCCESS_URL=https://yourdomain.com/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=

# =============================================================================
# AI PROVIDERS
# =============================================================================
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# =============================================================================
# AI OBSERVABILITY (Langfuse)
# =============================================================================
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# BACKGROUND JOBS (Trigger.dev)
# =============================================================================
TRIGGER_SECRET_KEY=tr_prod_xxxxxxxxxxxxx

# =============================================================================
# APPLICATION PORTS
# =============================================================================
SERVER_PORT=3000
WEB_PORT=3001
IMPERIUM_API_PORT=8010
IMPERIUM_WEB_PORT=3010

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=https://yourdomain.com
